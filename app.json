{
  "expo": {
    "name": "ChatAja!",
    "slug": "chataja",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Aplikasi memerlukan pengenalan suara untuk mengubah ucapan menjadi teks.",
        "NSMicrophoneUsageDescription": "Aplikasi memerlukan mikrofon untuk merekam suara Anda."
      }
    },
    "android": {
      "package": "com.bolt.scheduler",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Aplikasi memerlukan mikrofon untuk merekam suara Anda.",
          "speechRecognitionPermission": "Aplikasi memerlukan pengenalan suara untuk mengubah ucapan menjadi teks."
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "251ae02c-fc5b-47ff-a1ec-362d94c4be14"
      }
    }
  }
}
